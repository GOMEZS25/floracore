generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ROLES Y USUARIOS

model Role {
  role_id Int    @id @default(autoincrement())
  name    String @unique @db.VarChar(30)

  users User[]

  @@map("roles")
}

model User {
  user_id       BigInt   @id @default(autoincrement())
  role_id       Int?
  full_name     String   @db.VarChar(120)
  email         String   @unique @db.VarChar(120)
  password_hash String   @db.VarChar(255)
  is_active       Boolean  @default(true)
  is_super_admin  Boolean  @default(false)
  created_at      DateTime @default(now())

  role Role? @relation(fields: [role_id], references: [role_id])

  stock_movements  StockMovement[]
  forecast_runs    ForecastRun[]
  stock_thresholds StockThreshold[]
  packagings       Packaging[]
  lotes            Lote[]
  clients          Client[]
  sowings          Sowing[]
  sales_orders     SalesOrder[]
  attributes       Attribute[]
  preferences      UserPreference[]
  permissions      UserPermission[]

  @@index([role_id])
  @@index([is_active])
  @@map("users")
}

// PRODUCTOS Y CATEGORÍAS

model Category {
  category_id BigInt   @id @default(autoincrement())
  name        String   @unique @db.VarChar(60)
  reference   String   @unique @db.VarChar(20)
  is_active   Boolean  @default(true)
  created_by  BigInt
  created_at  DateTime @default(now())
  parent_id   BigInt?  // 

  parent   Category?  @relation("CategoryHierarchy", fields: [parent_id], references: [category_id], onDelete: Restrict)
  children Category[] @relation("CategoryHierarchy")

  products Product[]

  @@index([name])
  @@index([reference])
  @@index([is_active])
  @@index([parent_id])
  @@map("categories")
}

model Packaging {
  packaging_id Int               @id @default(autoincrement())
  name         String            @db.VarChar(60)
  reference    String            @unique @db.VarChar(20)
  category     PackagingCategory
  height       Decimal           @db.Decimal(8, 2)
  width        Decimal           @db.Decimal(8, 2)
  length       Decimal           @db.Decimal(8, 2)
  is_active    Boolean           @default(true)
  created_by   BigInt
  created_at   DateTime          @default(now())

  user     User      @relation(fields: [created_by], references: [user_id])
  products Product[]

  @@index([is_active])
  @@map("packaging")
}

model Product {
  product_id      BigInt   @id @default(autoincrement())
  sku             String   @unique @db.VarChar(40)
  name            String   @db.VarChar(120)
  category_id     BigInt
  unit_of_measure String   @db.VarChar(20)
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  product_type    ProductType @default(SIMPLE)

  packaging_id Int?
  packaging    Packaging? @relation(fields: [packaging_id], references: [packaging_id], onDelete: Restrict)
  category     Category   @relation(fields: [category_id], references: [category_id], onDelete: Restrict)

  lotes               Lote[]
  forecast_runs       ForecastRun[]
  stock_thresholds    StockThreshold[]
  sowing_details      SowingDetail[]
  projection_details  ProjectionDetail[]
  sales_order_details SalesOrderDetail[]
  variants            ProductVariant[]

  @@index([name])
  @@index([category_id])
  @@index([is_active])
  @@map("products")
}

// INVENTARIO

model InventoryLocation {
  location_id Int          @id @default(autoincrement())
  name        String       @unique @db.VarChar(60)
  description String?      @db.VarChar(200)
  type        LocationType
  parent_id   Int?
  is_active   Boolean      @default(true)

  parent   InventoryLocation?  @relation("LocationHierarchy", fields: [parent_id], references: [location_id], onDelete: Restrict)
  children InventoryLocation[] @relation("LocationHierarchy")

  lotes            Lote[]
  stock_thresholds StockThreshold[]
  sowings          Sowing[]

  @@index([parent_id])
  @@index([type])
  @@index([is_active])
  @@map("inventory_locations")
}

model Lote {
  lote_id             BigInt     @id @default(autoincrement())
  numero_lote         String     @unique @db.VarChar(40)
  product_id          BigInt
  variant_id          BigInt?
  location_id         Int
  cantidad_inicial    Decimal    @db.Decimal(10, 2)
  cantidad_disponible Decimal    @db.Decimal(10, 2)
  cantidad_reservada  Decimal    @default(0) @db.Decimal(10, 2)
  unidad_medida       String     @db.VarChar(20)
  estado              LoteEstado @default(DISPONIBLE)
  fecha_ingreso       DateTime   @default(now())
  zona_corte          String?    @db.VarChar(80)
  notas               String?    @db.VarChar(200)
  created_by          BigInt
  created_at          DateTime   @default(now())
  cantidad_cajas      Int?
  tipo_caja           TipoCaja?
  ramos_por_caja      Int?
  tallos_por_ramo     Int?
  week_number         Int?
  year                Int?

  product  Product           @relation(fields: [product_id], references: [product_id], onDelete: Restrict)
  variant ProductVariant?    @relation(fields: [variant_id], references: [variant_id], onDelete: Restrict)
  location InventoryLocation @relation(fields: [location_id], references: [location_id], onDelete: Restrict)
  user     User              @relation(fields: [created_by], references: [user_id])

  stock_movements StockMovement[]
  sales_order_details SalesOrderDetail[]

  @@index([product_id])
  @@index([location_id])
  @@index([estado])
  @@index([fecha_ingreso])
  @@index([variant_id])
  @@map("lotes")
}

model StockMovement {
  movement_id   BigInt       @id @default(autoincrement())
  lote_id       BigInt
  movement_type MovementType
  quantity      Decimal      @db.Decimal(10, 2)
  movement_date DateTime     @default(now())
  notes         String?      @db.VarChar(200)
  created_by    BigInt

  lote Lote @relation(fields: [lote_id], references: [lote_id], onDelete: Restrict)
  user User @relation(fields: [created_by], references: [user_id])

  @@index([lote_id])
  @@index([created_by])
  @@index([movement_type, movement_date])
  @@map("stock_movements")
}

// UMBRALES Y PROYECCIONES

model StockThreshold {
  threshold_id Int      @id @default(autoincrement())
  product_id   BigInt
  location_id  Int?
  min_quantity Int
  is_active    Boolean  @default(true)
  created_by   BigInt
  created_at   DateTime @default(now())

  product  Product            @relation(fields: [product_id], references: [product_id])
  location InventoryLocation? @relation(fields: [location_id], references: [location_id])
  user     User               @relation(fields: [created_by], references: [user_id])

  @@index([product_id])
  @@index([location_id])
  @@index([is_active])
  @@map("stock_thresholds")
}

model ForecastRun {
  forecast_id        BigInt            @id @default(autoincrement())
  product_id         BigInt
  forecast_name      String            @db.VarChar(80)
  date_from          DateTime          @db.Date
  date_to            DateTime          @db.Date
  period_granularity PeriodGranularity
  method             ForecastMethod
  horizon_periods    Int
  adjustment_factor  Decimal           @default(0.000) @db.Decimal(6, 3)
  created_by         BigInt
  created_at         DateTime          @default(now())

  product Product          @relation(fields: [product_id], references: [product_id])
  user    User             @relation(fields: [created_by], references: [user_id])
  periods ForecastPeriod[]

  @@index([product_id, created_at])
  @@index([created_by])
  @@map("forecast_runs")
}

model ForecastPeriod {
  forecast_period_id     BigInt   @id @default(autoincrement())
  forecast_id            BigInt
  period_start           DateTime @db.Date
  period_end             DateTime @db.Date
  demand_estimated       Int
  availability_estimated Int

  forecast_run ForecastRun @relation(fields: [forecast_id], references: [forecast_id], onDelete: Cascade)

  @@index([forecast_id])
  @@index([period_start, period_end])
  @@map("forecast_periods")
}

// SIEMBRA

model Sowing {
  sowing_id          BigInt       @id @default(autoincrement())
  location_id        Int
  planting_date      DateTime     @db.Date
  estimated_cut_week Int
  status             SowingStatus @default(ACTIVA)
  created_by         BigInt
  created_at         DateTime     @default(now())

  location InventoryLocation @relation(fields: [location_id], references: [location_id], onDelete: Restrict)
  user     User              @relation(fields: [created_by], references: [user_id])
  details  SowingDetail[]
  projections Projection[]

  @@index([location_id])
  @@index([status])
  @@index([planting_date])
  @@map("sowings")
}

model SowingDetail {
  detail_id     BigInt @id @default(autoincrement())
  sowing_id     BigInt
  product_id    BigInt
  stems_planted Int

  sowing  Sowing  @relation(fields: [sowing_id], references: [sowing_id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [product_id], onDelete: Restrict)

  @@index([sowing_id])
  @@index([product_id])
  @@map("sowing_details")
}

// PROYECCIONES DE SIEMBRA

model Projection {
  projection_id BigInt           @id @default(autoincrement())
  sowing_id     BigInt
  week_number   Int
  year          Int
  status        ProjectionStatus @default(PROYECTADO)
  created_at    DateTime         @default(now())

  sowing  Sowing             @relation(fields: [sowing_id], references: [sowing_id], onDelete: Cascade)
  details ProjectionDetail[]

  @@index([sowing_id])
  @@index([week_number, year])
  @@index([status])
  @@map("projections")
}

model ProjectionDetail {
  detail_id       BigInt @id @default(autoincrement())
  projection_id   BigInt
  product_id      BigInt
  stems_projected Int
  stems_actual    Int?

  projection Projection @relation(fields: [projection_id], references: [projection_id], onDelete: Cascade)
  product    Product    @relation(fields: [product_id], references: [product_id], onDelete: Restrict)

  @@index([projection_id])
  @@index([product_id])
  @@map("projection_details")
}

// ENUMS

enum LocationType {
  FINCA
  BLOQUE
  CAMA
}

enum SowingStatus {
  ACTIVA
  CERRADA
}

enum ProjectionStatus {
  PROYECTADO
  CORTADO
}

enum SalesOrderStatus {
  BORRADOR
  APROBADA
  DESPACHADA
  CANCELADA
}

enum PackagingType {
  TALLO
  RAMO
  CAJA
}

enum LoteEstado {
  DISPONIBLE
  RESERVADO
  AGOTADO
}

enum MovementType {
  ENTRADA
  VENTA
  DESPERDICIO
  RESERVA
  CANCELACION
  AJUSTE
}

enum TipoCaja {
  QUARTER_BOX
  HALF_BOX
  FULL_BOX
}

enum PackagingCategory {
  QUARTER_BOX
  HALF_BOX
  FULL_BOX
}

enum PeriodGranularity {
  DAY
  WEEK
  MONTH
}

enum ForecastMethod {
  HISTORICAL_AVG
  SIMPLE_TREND
}

enum ProductType {
  SIMPLE
  SURTIDO
  BOUQUET
}

enum InventoryMode {
  TALLOS
  RAMOS
  CAJAS
}

// VENTAS

model TransactionCategory {
  category_id Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(60)
  description String?  @db.VarChar(200)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  clients      Client[]
  sales_orders SalesOrder[]

  @@map("transaction_categories")
}

model SalesOrder {
  order_id                BigInt           @id @default(autoincrement())
  order_number            Int              @unique
  client_id               BigInt
  client_address_id       BigInt
  transaction_category_id Int?
  delivery_date           DateTime         @db.Date
  status                  SalesOrderStatus @default(BORRADOR)
  document_url            String?          @db.VarChar(500)
  notes                   String?          @db.VarChar(500)
  created_by              BigInt
  created_at              DateTime         @default(now())

  client               Client               @relation(fields: [client_id], references: [client_id], onDelete: Restrict)
  client_address       ClientAddress        @relation(fields: [client_address_id], references: [address_id], onDelete: Restrict)
  transaction_category TransactionCategory? @relation(fields: [transaction_category_id], references: [category_id], onDelete: Restrict)
  user                 User                 @relation(fields: [created_by], references: [user_id])
  details              SalesOrderDetail[]

  @@index([client_id])
  @@index([client_address_id])
  @@index([transaction_category_id])
  @@index([status])
  @@index([delivery_date])
  @@map("sales_orders")
}

model SalesOrderDetail {
  detail_id       BigInt        @id @default(autoincrement())
  order_id        BigInt
  lote_id         BigInt
  product_id      BigInt
  line_number     Int
  packaging_type  PackagingType
  quantity        Int
  stems_per_bunch Int?
  bunches_per_box Int?
  total_stems     Int
  total_bunches   Int?
  total_boxes     Int?
  unit_price      Decimal       @db.Decimal(10, 2)
  subtotal        Decimal       @db.Decimal(10, 2)
  notes           String?       @db.VarChar(300)
  created_at      DateTime      @default(now())

  order   SalesOrder @relation(fields: [order_id], references: [order_id], onDelete: Restrict)
  lote    Lote       @relation(fields: [lote_id], references: [lote_id], onDelete: Restrict)
  product Product    @relation(fields: [product_id], references: [product_id], onDelete: Restrict)

  @@index([order_id])
  @@index([lote_id])
  @@index([product_id])
  @@map("sales_order_details")
}

// CLIENTES

model Client {
  client_id      BigInt       @id @default(autoincrement())
  code           String       @unique @db.VarChar(20)
  name           String       @db.VarChar(120)
  origin         String       @db.VarChar(60)
  currency       String       @db.VarChar(10)
  delivery_terms String       @db.VarChar(80)
  status         ClientStatus @default(ACTIVO)
  is_active      Boolean      @default(true)
  transaction_category_id Int?
  created_by     BigInt
  created_at     DateTime     @default(now())

  user                 User                 @relation(fields: [created_by], references: [user_id])
  transaction_category TransactionCategory? @relation(fields: [transaction_category_id], references: [category_id], onDelete: Restrict)
  addresses            ClientAddress[]
  contacts             ClientContact[]
  sales_orders         SalesOrder[]

  @@index([code])
  @@index([status])
  @@index([is_active])
  @@map("clients")
}

model ClientAddress {
  address_id   BigInt      @id @default(autoincrement())
  client_id    BigInt
  address_type AddressType
  address_line String      @db.VarChar(200)
  city         String      @db.VarChar(60)
  country      String      @db.VarChar(60)
  is_active    Boolean     @default(true)
  created_at   DateTime    @default(now())

  client       Client       @relation(fields: [client_id], references: [client_id], onDelete: Restrict)
  sales_orders SalesOrder[]

  @@index([client_id])
  @@index([address_type])
  @@map("client_addresses")
}

model ClientContact {
  contact_id BigInt   @id @default(autoincrement())
  client_id  BigInt
  full_name  String   @db.VarChar(120)
  email      String   @db.VarChar(120)
  phone      String   @db.VarChar(30)
  role       String   @db.VarChar(60)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  client Client @relation(fields: [client_id], references: [client_id], onDelete: Restrict)

  @@index([client_id])
  @@map("client_contacts")
}

enum ClientStatus {
  ACTIVO
  INACTIVO
}

enum AddressType {
  FISCAL
  ENTREGA
}

// ATRIBUTOS Y VARIANTES

model Attribute {
  attribute_id BigInt   @id @default(autoincrement())
  name         String   @unique @db.VarChar(60)
  is_active    Boolean  @default(true)
  order        Int      @default(0)
  created_by   BigInt
  created_at   DateTime @default(now())

  user   User             @relation(fields: [created_by], references: [user_id])
  values AttributeValue[]

  @@index([created_by])
  @@index([is_active])
  @@map("attributes")
}

model AttributeValue {
  value_id     BigInt  @id @default(autoincrement())
  attribute_id BigInt
  value        String  @db.VarChar(60)
  is_active    Boolean @default(true)
  created_at   DateTime @default(now())

  attribute  Attribute              @relation(fields: [attribute_id], references: [attribute_id], onDelete: Cascade)
  variant_attributes ProductVariantAttribute[]

  @@index([attribute_id])
  @@map("attribute_values")
}

model ProductVariant {
  variant_id  BigInt   @id @default(autoincrement())
  product_id  BigInt
  sku_variant String   @unique @db.VarChar(60)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  product    Product                  @relation(fields: [product_id], references: [product_id], onDelete: Restrict)
  attributes ProductVariantAttribute[]
  lotes      Lote[]

  @@index([product_id])
  @@map("product_variants")
}

model ProductVariantAttribute {
  id         BigInt @id @default(autoincrement())
  variant_id BigInt
  value_id   BigInt

  variant ProductVariant @relation(fields: [variant_id], references: [variant_id], onDelete: Cascade)
  value   AttributeValue @relation(fields: [value_id], references: [value_id], onDelete: Restrict)

  @@index([variant_id])
  @@index([value_id])
  @@map("product_variant_attributes")
}

// PERMISOS

enum UserModule {
  PRODUCTS
  INVENTORY
  FARM
  SALES
  CLIENTS
  SETTINGS
  REPORTS
}

model UserPermission {
  permission_id BigInt     @id @default(autoincrement())
  user_id       BigInt
  module        UserModule
  can_view      Boolean    @default(false)
  can_create    Boolean    @default(false)
  can_edit      Boolean    @default(false)
  can_delete    Boolean    @default(false)
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([user_id, module])
  @@index([user_id])
  @@map("user_permissions")
}


model CompanySettings {
  id                   Int           @id @default(autoincrement())
  inventory_mode       InventoryMode @default(TALLOS)
  show_stems_per_bunch Boolean       @default(false)
  show_bunches_per_box Boolean       @default(false)
  show_box_type        Boolean       @default(false)
  created_at           DateTime      @default(now())
  updated_at           DateTime      @updatedAt

  @@map("company_settings")
}




model UserPreference {
  id               BigInt   @id @default(autoincrement())
  user_id          BigInt
  preference_key   String   @db.VarChar(60)
  preference_value Json
  updated_at       DateTime @updatedAt

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([user_id, preference_key])
  @@index([user_id])
  @@map("user_preferences")
}